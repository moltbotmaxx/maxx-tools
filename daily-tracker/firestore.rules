rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /daily-tracker-data/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidPayload();
      allow delete: if isOwner(userId);

      function isValidPayload() {
        return request.resource.data.keys().hasOnly(['appData', 'permanentNotes', 'doneHeadlines', 'managedSentientAccounts', 'lastUpdated'])
          && request.resource.data.appData is map
          && request.resource.data.appData.keys().hasOnly(['pool', 'schedule', 'ideas'])
          && request.resource.data.appData.pool is list
          && request.resource.data.appData.schedule is map
          && request.resource.data.appData.ideas is list
          && request.resource.data.doneHeadlines is list
          && request.resource.data.doneHeadlines.size() <= 5000
          && (
            !request.resource.data.keys().hasAny(['managedSentientAccounts']) ||
            (
              request.resource.data.managedSentientAccounts is list
              && request.resource.data.managedSentientAccounts.size() <= 50
            )
          )
          && request.resource.data.permanentNotes is string
          && request.resource.data.permanentNotes.size() <= 20000
          && request.resource.data.lastUpdated is string;
      }

      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
    }

    match /daily-tracker-team-selections/{selectionDocId} {
      allow read: if request.auth != null;
      allow create, update: if isTeamSelectionOwnerForWrite();
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;

      function isTeamSelectionOwnerForWrite() {
        return request.auth != null
          && request.resource.data.ownerUid == request.auth.uid
          && isValidTeamSelectionPayload();
      }

      function isValidTeamSelectionPayload() {
        return request.resource.data.keys().hasOnly([
            'selectionId',
            'ownerUid',
            'ownerLabel',
            'title',
            'url',
            'type',
            'notesPreview',
            'selectedAt',
            'updatedAt'
          ])
          && request.resource.data.selectionId is string
          && request.resource.data.selectionId.size() <= 120
          && request.resource.data.ownerUid is string
          && request.resource.data.ownerUid.size() <= 128
          && request.resource.data.ownerLabel is string
          && request.resource.data.ownerLabel.size() <= 200
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 300
          && request.resource.data.url is string
          && request.resource.data.url.size() <= 2000
          && request.resource.data.type is string
          && ['post', 'reel', 'promo'].hasAny([request.resource.data.type])
          && request.resource.data.notesPreview is string
          && request.resource.data.notesPreview.size() <= 280
          && request.resource.data.selectedAt is string
          && request.resource.data.updatedAt is string;
      }
    }

    // Deny access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
